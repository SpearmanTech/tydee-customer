rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isAuthenticated() { return request.auth != null; }
    function isVerified() { return isAuthenticated() && request.auth.token.email_verified == true; }
    // FIX: Use request.resource for creation checks, and resource for existing data checks
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() { return isAuthenticated() && request.auth.token.email == "your-admin-email@example.com"; }

    // --- 1. USERS & PROFILES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /professionals/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || isAdmin();
    }

   // --- 2. THE WAITLIST ECOSYSTEM ---
    match /waitlist_employed/{docId} {
      // Change isVerified() to isAuthenticated() for testing
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated(); 
      allow delete, update: if isAdmin();
    }

    match /waitlist_unemployed/{docId} {
      // Change isVerified() to isAuthenticated() for testing
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated();  
      allow delete, update: if isAdmin();
    }

    // --- 3. JOBS, BIDS & SQUADS ---
    match /jobs/{jobId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.professionalId == request.auth.uid ||
        resource.data.status == 'pending' ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.customerId) || 
        isOwner(resource.data.professionalId) ||
        isAdmin()
      );

      match /bids/{bidId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated(); // Removed isProfessional check to allow waitlisted pros to bid later
        allow update, delete: if isOwner(resource.data.professionalId) || isAdmin();
      }
    }

    match /squad_marketplace/{squadJobId} {
      allow read: if isAuthenticated() || isAdmin();
      allow create, update: if isAuthenticated() && (
        request.resource.data.leadProId == request.auth.uid || 
        isAdmin()
      );
    }

    // --- 4. EQUIPMENT & RENTALS ---
    match /equipment/{item} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin(); 
    }

    match /rentals/{rental} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.customerId) || 
        isOwner(resource.data.listerId) ||
        isAdmin()
      );
      allow write: if isAdmin(); 
    }

    // --- 5. SYSTEM DEFAULTS ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}